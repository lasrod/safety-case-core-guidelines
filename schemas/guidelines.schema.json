{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Safety Case Core Guidelines",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "document", "reference_sources", "categories", "guidelines"],
  "properties": {
    "schema_version": { "const": "0.4.0" },

    "document": {
      "type": "object",
      "additionalProperties": true,
      "required": ["title"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "copyright": { "type": "string" },
        "license": { "type": "object" },
        "purpose": { "type": "string" },
        "source_policy": { "type": "object" },
        "id_scheme": { "type": "array" },
        "required_guideline_sections": { "type": "array", "items": { "type": "string" } }
      }
    },

    "reference_sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "display_name"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "display_name": { "type": "string", "minLength": 1 },
          "type": { "type": "string" }
        }
      }
    },

    "categories": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Z]{2}$" },
          "title": { "type": "string", "minLength": 1 },
          "index_title": { "type": ["string", "null"] },
          "description": { "type": ["string", "null"] }
        }
      }
    },

    "guidelines": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id", "category", "title",
          "guideline", "why", "review_prompts", "example",
          "references"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Z]{2}\\.\\d+$" },
          "category": { "type": "string", "pattern": "^[A-Z]{2}$" },
          "title": { "type": "string", "minLength": 1 },
          "guideline": { "type": "string", "minLength": 1 },
          "why": { "type": "string", "minLength": 1 },
          "review_prompts": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "example": {
            "type": "object",
            "additionalProperties": false,
            "required": ["bad", "problem", "good"],
            "properties": {
              "bad": { "type": "string", "minLength": 1 },
              "problem": { "type": "string", "minLength": 1 },
              "good": { "type": "string", "minLength": 1 }
            }
          },
          "references": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["source_id"],
              "properties": {
                "source_id": { "type": "string", "minLength": 1 },
                "display_name": { "type": "string", "minLength": 1 },
                "clauses": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          },
          "tool_guidance": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "applicable_elements": { "type": "array", "items": { "type": "string" } },
              "detection_hints": { "type": "array", "items": { "type": "string" } },
              "suggested_checks": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["id", "description"],
                  "properties": {
                    "id": { "type": "string", "minLength": 1 },
                    "description": { "type": "string", "minLength": 1 }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
