{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Safety Case Core Guidelines",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "document", "reference_sources", "categories", "guidelines"],
  "properties": {
    "schema_version": { "type": "string" },

    "document": {
      "type": "object",
      "additionalProperties": true,
      "required": ["title"],
      "properties": {
        "title": { "type": "string" },
        "copyright": { "type": "string" },
        "license": { "type": "object" },
        "purpose": { "type": "string" },
        "source_policy": { "type": "object" },
        "id_scheme": { "type": "array" },
        "required_guideline_sections": { "type": "array", "items": { "type": "string" } },
        "review_comment_examples": { "type": "array" }
      }
    },

    "reference_sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "display_name"],
        "properties": {
          "id": { "type": "string" },
          "display_name": { "type": "string" },
          "type": { "type": "string" }
        }
      }
    },

    "categories": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "order"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Z]{2}$" },
          "title": { "type": "string" },
          "index_title": { "type": ["string", "null"] },
          "description": { "type": ["string", "null"] },
          "order": { "type": "integer" }
        }
      }
    },

    "migration_notes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["guideline_id", "note"],
        "properties": {
          "guideline_id": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    },

    "guidelines": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id", "category", "number", "title", "order",
          "guideline", "why", "review_prompts", "example",
          "references"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Z]{2}\\.\\d+$" },
          "category": { "type": "string", "pattern": "^[A-Z]{2}$" },
          "number": { "type": "integer", "minimum": 1 },
          "title": { "type": "string", "minLength": 1 },
          "order": { "type": "integer" },
          "guideline": { "type": "string", "minLength": 1 },
          "why": { "type": "string", "minLength": 1 },
          "review_prompts": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "example": {
            "type": "object",
            "additionalProperties": false,
            "required": ["markdown", "cases"],
            "properties": {
              "markdown": { "type": "string", "minLength": 1 },
              "cases": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": true,
                  "required": ["role"],
                  "properties": {
                    "label": { "type": "string" },
                    "role": {
                      "type": "string",
                      "enum": ["bad", "better", "good", "problem", "informative"]
                    },
                    "text": { "type": "string" },
                    "elements": { "type": "object" }
                  }
                }
              }
            }
          },
          "note": { "type": "string", "minLength": 1 },
          "references": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["source_id"],
              "properties": {
                "source_id": { "type": "string", "minLength": 1 },
                "display_name": { "type": "string" },
                "clauses": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          },
          "tool_guidance": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "applicable_elements": { "type": "array", "items": { "type": "string" } },
              "detection_hints": { "type": "array", "items": { "type": "string" } },
              "suggested_checks": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["id", "description"],
                  "properties": {
                    "id": { "type": "string" },
                    "description": { "type": "string" }
                  }
                }
              },
              "suggested_ai_prompt": { "type": "string" }
            }
          },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
